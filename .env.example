# GitHub Token（必需）
# 用于获取 GitHub 用户信息和仓库列表
GITHUB_TOKEN=your_github_token_here

# S3 兼容存储（可选）
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_DOMAIN=

# to 短链服务（可选，用于外链点击统计）
# 在 to 平台的工作区设置中创建 API Key
TO_API_URL=https://to.example.com
TO_API_KEY=to_sk_xxx
